{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://andre-simplifica.github.io/oracle-apex-brand-report-kit/schemas/installation-manifest.schema.json",
  "title": "Oracle APEX Brand Report Kit installation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "skill_version", "runtime_version", "schema_versions", "theme", "installed_at", "managed_files", "project_files", "features", "compatibility"],
  "properties": {
    "manifest_version": {"const": "1.0"},
    "skill_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "runtime_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_versions": {
      "type": "object", "additionalProperties": false, "required": ["brand", "report", "manifest"],
      "properties": {"brand": {"type": "string"}, "report": {"type": "string"}, "manifest": {"type": "string"}}
    },
    "theme": {
      "type": "object", "additionalProperties": false, "required": ["id", "version"],
      "properties": {"id": {"type": "string"}, "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}}
    },
    "installed_at": {"type": "string", "format": "date-time"},
    "managed_files": {
      "type": "object", "additionalProperties": false, "required": ["engine", "theme"],
      "properties": {
        "engine": {"$ref": "#/$defs/files"},
        "theme": {"$ref": "#/$defs/files"}
      }
    },
    "project_files": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}},
    "features": {
      "type": "object", "additionalProperties": {"type": "boolean"},
      "required": ["fullscreen", "print", "pdf", "xlsx", "csv"]
    },
    "compatibility": {
      "type": "object", "additionalProperties": false, "required": ["oracle_database", "oracle_apex"],
      "properties": {
        "oracle_database": {"$ref": "#/$defs/compatibility"},
        "oracle_apex": {"$ref": "#/$defs/compatibility"}
      }
    }
  },
  "$defs": {
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9_.\\/-]+$"},
    "files": {
      "type": "array", "items": {
        "type": "object", "additionalProperties": false, "required": ["path", "sha256"],
        "properties": {"path": {"$ref": "#/$defs/relativePath"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
      }
    },
    "compatibility": {
      "type": "object", "additionalProperties": false, "required": ["status", "version", "evidence"],
      "properties": {
        "status": {"enum": ["confirmed", "expected-not-tested", "unsupported", "unknown"]},
        "version": {"type": "string", "minLength": 1},
        "evidence": {"type": "string", "minLength": 1}
      }
    }
  }
}
