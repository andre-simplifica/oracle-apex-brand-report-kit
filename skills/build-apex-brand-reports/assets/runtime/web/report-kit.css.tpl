/* Optional static copy. The essential baseline is also returned inline by {{ENGINE_PACKAGE}}. */
.abrk{--abrk-content-width:{{CONTENT_WIDTH}};container-name:abrk;container-type:inline-size;-webkit-print-color-adjust:exact;print-color-adjust:exact}
.abrk[data-orientation="landscape"]{--abrk-page-width:297mm;--abrk-page-height:210mm}
.abrk[data-repeat-table-header="false"] .abrk__table thead{display:table-row-group}
@media print{@page{size:A4 {{ORIENTATION}};margin:14mm}.abrk[data-economy-print="true"]{-webkit-print-color-adjust:economy;print-color-adjust:economy}}
